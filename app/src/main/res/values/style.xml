<?xml version="1.0" encoding="utf-8"?>
<resources>
	<style name="AppTheme" parent="@android:style/Theme.Holo">
		<item name="android:actionBarWidgetTheme">@android:style/Theme.Holo</item>
		<item name="android:popupMenuStyle">@style/AppPopupMenu</item>
		<item name="android:itemTextAppearance">@style/AppPopupItemText</item>
	</style>

	<style name="AppPopupMenu" parent="@android:style/Widget.Holo.PopupMenu">
		<item name="android:popupBackground">#212121</item>
	</style>

	<style name="AppPopupItemText" parent="@android:style/TextAppearance.Holo.Widget.PopupMenu.Large">
		<item name="android:textColor">@color/jabtalkWhite</item>
	</style>

	<style name="picture_text">
		<item name="android:textSize">17sp</item>
		<item name="android:textColor">@color/jabtalkWhite</item>
		<item name="android:layout_height">wrap_content</item>
		<item name="android:layout_width">wrap_content</item>
		<item name="android:layout_centerHorizontal">true</item>
		<item name="android:layout_alignParentTop">true</item>	
		<item name="android:layout_marginTop">2dp</item>
		<item name="android:textStyle">bold</item>
		<item name="android:gravity">center</item>
	</style>
	
	<style name="picture">
		<item name="android:layout_height">wrap_content</item>
		<item name="android:layout_width">wrap_content</item>
		<item name="android:layout_centerHorizontal">true</item>
		<item name="android:padding">3dp</item>
		<item name="android:layout_below">@id/title</item>	
	</style>	
	
	<style name="jabtalk_button">
		<item name="android:layout_height">wrap_content</item>
		<item name="android:layout_width">wrap_content</item>
		<item name="android:background">@drawable/button_clickable</item>
		<item name="android:textColor">@color/jabtalkBlack</item>
	</style>

	<style name="StatsTable">
		<item name="android:layout_width">match_parent</item>
		<item name="android:layout_height">wrap_content</item>
		<item name="android:orientation">vertical</item>
		<item name="android:background">@drawable/stats_table_border</item>
	</style>

	<style name="StatsHeaderRow">
		<item name="android:layout_width">match_parent</item>
		<item name="android:layout_height">wrap_content</item>
		<item name="android:orientation">horizontal</item>
		<item name="android:background">@color/jabtalkStatsHeader</item>
		<item name="android:paddingLeft">10dp</item>
		<item name="android:paddingRight">10dp</item>
		<item name="android:paddingTop">8dp</item>
		<item name="android:paddingBottom">8dp</item>
	</style>

	<style name="StatsHeaderText">
		<item name="android:layout_height">wrap_content</item>
		<item name="android:textColor">@color/jabtalkWhite</item>
		<item name="android:textSize">14sp</item>
		<item name="android:textStyle">bold</item>
	</style>

	<style name="StatsFooterRow">
		<item name="android:layout_width">match_parent</item>
		<item name="android:layout_height">wrap_content</item>
		<item name="android:orientation">horizontal</item>
		<item name="android:gravity">right</item>
		<item name="android:paddingLeft">10dp</item>
		<item name="android:paddingRight">10dp</item>
		<item name="android:paddingTop">8dp</item>
		<item name="android:paddingBottom">8dp</item>
	</style>

	<style name="StatsViewAllLink">
		<item name="android:layout_width">wrap_content</item>
		<item name="android:layout_height">wrap_content</item>
		<item name="android:textColor">@color/jabtalkStatsLink</item>
		<item name="android:textSize">13sp</item>
		<item name="android:textStyle">bold</item>
		<item name="android:padding">6dp</item>
		<item name="android:clickable">true</item>
		<item name="android:background">?android:attr/selectableItemBackground</item>
	</style>

</resources>
