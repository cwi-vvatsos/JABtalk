<?xml version="1.0" encoding="utf-8"?>
<resources>
	<style name="AppTheme" parent="@android:style/Theme.Holo">
		<item name="android:actionBarWidgetTheme">@android:style/Theme.Holo</item>
		<item name="android:popupMenuStyle">@style/AppPopupMenu</item>
		<item name="android:itemTextAppearance">@style/AppPopupItemText</item>
	</style>

	<style name="AppPopupMenu" parent="@android:style/Widget.Holo.PopupMenu">
		<item name="android:popupBackground">#212121</item>
	</style>

	<style name="AppPopupItemText" parent="@android:style/TextAppearance.Holo.Widget.PopupMenu.Large">
		<item name="android:textColor">@color/jabtalkWhite</item>
	</style>

	<style name="picture_text">
		<item name="android:textSize">17sp</item>
		<item name="android:textColor">@color/jabtalkWhite</item>
		<item name="android:layout_height">wrap_content</item>
		<item name="android:layout_width">wrap_content</item>
		<item name="android:layout_centerHorizontal">true</item>
		<item name="android:layout_alignParentTop">true</item>	
		<item name="android:layout_marginTop">2dp</item>
		<item name="android:textStyle">bold</item>
		<item name="android:gravity">center</item>
	</style>
	
	<style name="picture">
		<item name="android:layout_height">wrap_content</item>
		<item name="android:layout_width">wrap_content</item>
		<item name="android:layout_centerHorizontal">true</item>
		<item name="android:padding">3dp</item>
		<item name="android:layout_below">@id/title</item>	
	</style>	
	
	<style name="jabtalk_button">	    
		<item name="android:layout_height">wrap_content</item>
		<item name="android:layout_width">wrap_content</item>
		<item name="android:background">@drawable/button_clickable</item>
		<item name="android:textColor">@color/jabtalkBlack</item>
	</style>		
	
</resources>
